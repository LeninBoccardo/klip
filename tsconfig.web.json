{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "./src/renderer/**/*.ts",
    "./src/renderer/**/*.tsx",
    "./src/renderer/**/*.d.ts",
    "./src/preload/*.d.ts",
    "./src/shared/**/*",
  ],
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": [
        "./src/renderer/*"
      ],
      "@renderer/*": [
        "./src/renderer/src/*"
      ],
      "@components/*": [
        "./src/renderer/components/*"
      ],
      "@ui/*": [
        "./src/renderer/components/ui/*"
      ],
      "@main/*": [
        "./src/main/*"
      ],
      "@domain/*": [
        "./src/main/domain/*"
      ],
      "@use-cases/*": [
        "./src/main/use-cases/*"
      ],
      "@shared/*": [
        "./src/shared/*"
      ],
      "@preload/*": [
        "./src/preload/*"
      ]
    }
  }
}
