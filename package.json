{
  "name": "klip",
  "version": "0.0.1",
  "description": "A local, offline-first desktop asset manager designed to organize downloaded source videos and manually created video cuts",
  "main": "./out/main/index.js",
  "author": "github.com/LeninBoccardo",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "rebuild": "node node_modules/@electron/rebuild/lib/cli.js -f -w better-sqlite3",
    "dev": "npm run rebuild && electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps && electron-rebuild -f -w better-sqlite3",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux",
    "pretest": "npm rebuild better-sqlite3",
    "test": "vitest run",
    "test:watch": "npm rebuild better-sqlite3 && vitest",
    "test:main": "npm rebuild better-sqlite3 && vitest run --project main",
    "test:renderer": "vitest run --project renderer",
    "test:coverage": "npm rebuild better-sqlite3 && vitest run --coverage",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run test",
    "smoke": "npm run rebuild && tsx scripts/smoke-dev.ts",
    "e2e": "npm run build && playwright test",
    "e2e:ui": "playwright test --ui",
    "check:full": "npm run check && npm run smoke",
    "setup": "npm install && tsx scripts/download-binaries.ts && npm run rebuild",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@dnd-kit/react": "^0.4.0",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
    "@marshallofsound/ipc": "^2.7.0",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-router": "^1.169.1",
    "@tanstack/react-router-devtools": "^1.166.13",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.24",
    "better-sqlite3": "12.9.0",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "i18next": "^26.0.8",
    "lucide-react": "^1.14.0",
    "next-themes": "^0.4.6",
    "p-queue": "^9.2.0",
    "radix-ui": "^1.4.3",
    "react-day-picker": "^9.14.0",
    "react-hook-form": "^7.75.0",
    "react-hotkeys-hook": "^5.3.0",
    "react-i18next": "^17.0.6",
    "react-resizable-panels": "^4.11.0",
    "react-router": "^7.14.2",
    "recharts": "^3.8.1",
    "shadcn": "^4.6.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron/rebuild": "^4.0.4",
    "@hookform/devtools": "^4.4.0",
    "@playwright/test": "^1.59.1",
    "@stryker-mutator/core": "^9.6.1",
    "@tanstack/router-plugin": "^1.167.32",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.5",
    "drizzle-kit": "^0.31.10",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jsdom": "^29.1.1",
    "knip": "^6.11.0",
    "prettier": "^3.8.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
