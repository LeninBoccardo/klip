{
  "name": "klip",
  "version": "0.0.1",
  "description": "A local, offline-first desktop asset manager designed to organize downloaded source videos and manually created video cuts",
  "main": "./out/main/index.js",
  "author": "github.com/LeninBoccardo",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "rebuild": "node node_modules/@electron/rebuild/lib/cli.js -f -w better-sqlite3",
    "dev": "npm run rebuild && electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps && electron-rebuild -f -w better-sqlite3",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux",
    "pretest": "npm rebuild better-sqlite3",
    "test": "vitest run",
    "test:watch": "npm rebuild better-sqlite3 && vitest",
    "test:main": "npm rebuild better-sqlite3 && vitest run --project main",
    "test:renderer": "vitest run --project renderer",
    "test:coverage": "npm rebuild better-sqlite3 && vitest run --coverage",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run test",
    "smoke": "npm run rebuild && tsx scripts/smoke-dev.ts",
    "e2e": "npm run build && playwright test",
    "e2e:ui": "playwright test --ui",
    "check:full": "npm run check && npm run smoke",
    "setup": "npm install && tsx scripts/download-binaries.ts && npm run rebuild",
    "clean": "tsx scripts/clean-app-data.ts",
    "logs:clear": "tsx scripts/clear-logs.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@atlaskit/pragmatic-drag-and-drop": "1.8.1",
    "@base-ui/react": "1.4.1",
    "@electron-toolkit/preload": "3.0.2",
    "@electron-toolkit/utils": "4.0.0",
    "@fontsource-variable/geist": "5.2.9",
    "@hookform/resolvers": "5.4.0",
    "@tailwindcss/vite": "4.3.1",
    "@tanstack/react-query": "5.101.0",
    "@tanstack/react-router": "1.170.16",
    "@tanstack/react-router-devtools": "1.167.0",
    "@tanstack/react-virtual": "3.14.3",
    "better-sqlite3": "12.9.0",
    "chokidar": "5.0.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "4.4.0",
    "drizzle-orm": "0.45.2",
    "electron-log": "5.4.4",
    "electron-updater": "6.8.9",
    "i18next": "26.3.1",
    "lucide-react": "1.20.0",
    "next-themes": "0.4.6",
    "p-queue": "9.3.0",
    "radix-ui": "1.6.0",
    "react-day-picker": "10.0.1",
    "react-hook-form": "7.79.0",
    "react-i18next": "17.0.8",
    "react-resizable-panels": "4.11.2",
    "recharts": "3.8.1",
    "shadcn": "4.11.0",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.1",
    "tw-animate-css": "1.4.0",
    "zod": "4.4.3",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "3.0.0",
    "@electron-toolkit/eslint-config-ts": "3.1.0",
    "@electron-toolkit/tsconfig": "2.0.0",
    "@electron/rebuild": "4.0.4",
    "@hookform/devtools": "4.4.0",
    "@playwright/test": "1.61.0",
    "@stryker-mutator/core": "9.6.1",
    "@tanstack/router-plugin": "1.168.18",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "24.12.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "@vitest/coverage-v8": "4.1.9",
    "drizzle-kit": "0.31.10",
    "electron": "41.5.0",
    "electron-builder": "26.15.3",
    "electron-vite": "5.0.0",
    "eslint": "9.39.4",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "jsdom": "29.1.1",
    "knip": "6.17.1",
    "prettier": "3.8.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vite": "7.3.3",
    "vitest": "4.1.9"
  }
}
