{
  "files": [],
  "references": [{ "path": "./tsconfig.node.json" }, { "path": "./tsconfig.web.json" }],
  "compilerOptions": {
    "paths": {
      "@/*": [
        "./src/renderer/*"
      ],
      "@renderer/*": [
        "./src/renderer/src/*"
      ],
      "@components/*": [
        "./src/renderer/components/*"
      ],
      "@ui/*": [
        "./src/renderer/components/ui/*"
      ],
      "@main/*": [
        "./src/main/*"
      ],
      "@domain/*": [
        "./src/main/domain/*"
      ],
      "@use-cases/*": [
        "./src/main/use-cases/*"
      ],
      "@shared/*": [
        "./src/shared/*"
      ],
      "@preload/*": [
        "./src/preload/*"
      ]
    }
  }
}
